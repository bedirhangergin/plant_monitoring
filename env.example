# ============================================================================
# Plant Growth Monitor — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# Load with: source .env   OR   pip install python-dotenv and load in code.
# ============================================================================

# Layer 3: Gemini Flash API key (required to enable Layer 3 fallback)
# Get a free key at: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Override the cascade confidence threshold (default: 0.60)
# CONFIDENCE_THRESHOLD=0.60

# Optional: Override the Gemini model variant (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: Override the HSV green ratio threshold (default: 0.01)
# HSV_GREEN_RATIO_THRESHOLD=0.01
